# ============================================
# Python FastAPI 后端 - 环境变量配置
# ============================================

# --------------------------------------------
# 1. 基础服务配置
# --------------------------------------------
APP_NAME=智教未来API
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# API 服务端口
PORT=8000
HOST=0.0.0.0

# 工作进程数 (0=自动, 建议CPU核心数)
WORKERS=1

# --------------------------------------------
# 2. 安全配置
# --------------------------------------------

# JWT 密钥 (请务必修改!)
SECRET_KEY=your-super-secret-key-change-this-in-production

# 访问令牌过期时间 (分钟)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 刷新令牌过期时间 (天)
REFRESH_TOKEN_EXPIRE_DAYS=7

# 算法
ALGORITHM=HS256

# --------------------------------------------
# 3. 数据库配置 (PostgreSQL)
# --------------------------------------------

# 异步数据库URL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/zhijiao

# 同步数据库URL (用于 alembic 迁移)
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/zhijiao

# 连接池配置
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_ECHO=false

# --------------------------------------------
# 4. Redis 配置
# --------------------------------------------

REDIS_URL=redis://localhost:6379/0

# Redis 连接池
REDIS_POOL_SIZE=10

# 缓存过期时间 (秒)
CACHE_DEFAULT_EXPIRE=300
CACHE_USER_EXPIRE=600
CACHE_GENERATION_EXPIRE=3600

# --------------------------------------------
# 5. LinkAI 服务配置
# --------------------------------------------

# LinkAI API 基础地址
LINKAI_API_BASE=http://localhost:8080

# LinkAI API 密钥
LINKAI_API_KEY=your-linkai-api-key-here

# 请求超时时间 (秒)
LINKAI_TIMEOUT=60

# 最大重试次数
LINKAI_MAX_RETRIES=3

# LinkAI 四大AI功能工作流编码
# 在 LinkAI 平台分别创建4个工作流，然后填写对应的 workflow code

# AI教案·大单元 - 用于生成完整教学设计
LINKAI_WORKFLOW_LESSON=lesson_plan_workflow

# AI命题 - 用于生成考试题目
LINKAI_WORKFLOW_QUESTION=question_gen_workflow

# AI组题 - 用于组合完整试卷
LINKAI_WORKFLOW_EXAM=exam_gen_workflow

# AI互动课件/教学动画 - 用于生成教学动画脚本
LINKAI_WORKFLOW_ANIMATION=animation_workflow

# --------------------------------------------
# 6. 作业批改中台配置
# --------------------------------------------

CORRECTION_API_BASE=http://localhost:3005
CORRECTION_API_KEY=your-correction-api-key-here
CORRECTION_TIMEOUT=30

# --------------------------------------------
# 7. 日志配置
# --------------------------------------------

# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 日志格式: json, console
LOG_FORMAT=console

# 是否输出到文件
LOG_TO_FILE=false

# 日志文件路径 (启用文件日志时)
LOG_FILE_PATH=./logs/app.log

# 日志轮转天数
LOG_RETENTION_DAYS=30

# --------------------------------------------
# 8. CORS 配置
# --------------------------------------------

# 允许的源 (逗号分隔, * 表示允许所有)
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# 允许的 HTTP 方法
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH

# 允许的请求头
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-Requested-With

# 允许携带凭证
CORS_ALLOW_CREDENTIALS=true

# --------------------------------------------
# 9. 限流配置
# --------------------------------------------

# 是否启用限流
RATE_LIMIT_ENABLED=true

# 默认限流: 每IP每分钟最大请求数
RATE_LIMIT_DEFAULT=100

# 登录接口限流: 每分钟最大尝试次数
RATE_LIMIT_LOGIN=5

# AI生成接口限流: 每分钟最大请求数
RATE_LIMIT_GENERATION=10

# --------------------------------------------
# 10. 文件上传配置
# --------------------------------------------

# 上传文件大小限制 (MB)
UPLOAD_MAX_SIZE=10

# 允许的文件类型 (逗号分隔)
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,application/pdf

# 上传文件存储路径
UPLOAD_DIR=./uploads

# 文件访问URL前缀
UPLOAD_URL_PREFIX=/uploads