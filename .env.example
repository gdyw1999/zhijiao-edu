# ============================================
# 智教未来 - 环境变量配置模板
# ============================================
# 使用方法：
#   1. 复制此文件为 .env
#   2. 修改下方的配置值
#   3. 运行启动脚本
# ============================================

# --------------------------------------------
# 1. 服务端口配置
# --------------------------------------------
BACKEND_PORT=8000
FRONTEND_PORT=3000

# --------------------------------------------
# 2. 后端服务配置
# --------------------------------------------
NODE_ENV=development
LOG_LEVEL=debug

# 数据库配置 (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zhijiao?schema=public

# Redis配置 (缓存和会话)
REDIS_URL=redis://localhost:6379

# --------------------------------------------
# 3. AI服务配置 (LinkAI)
# --------------------------------------------

# LinkAI API 基础地址
LINKAI_API_BASE=http://localhost:8080

# LinkAI API 密钥
LINKAI_API_KEY=your-linkai-api-key-here

# LinkAI 四大AI功能工作流编码
# 在 LinkAI 平台分别创建4个工作流，然后填写对应的 workflow code

# AI教案·大单元 - 用于生成完整教学设计
LINKAI_WORKFLOW_LESSON=lesson_plan_workflow

# AI命题 - 用于生成考试题目
LINKAI_WORKFLOW_QUESTION=question_gen_workflow

# AI组题 - 用于组合完整试卷
LINKAI_WORKFLOW_EXAM=exam_gen_workflow

# AI互动课件/教学动画 - 用于生成教学动画脚本
LINKAI_WORKFLOW_ANIMATION=animation_workflow

# --------------------------------------------
# 4. 作业批改中台配置
# --------------------------------------------
CORRECTION_API_BASE=http://localhost:3005
CORRECTION_API_KEY=your-correction-api-key-here

# --------------------------------------------
# 5. 安全配置
# --------------------------------------------
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRES_IN=7d

# --------------------------------------------
# 6. 对象存储配置 (MinIO)
# --------------------------------------------
STORAGE_TYPE=minio
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=zhijiao
